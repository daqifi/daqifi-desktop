<UserControl x:Class="Daqifi.Desktop.View.Prototype.ChannelsPanePrototype"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:vm="clr-namespace:Daqifi.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChannelsPaneViewModel}"
             d:DesignHeight="800" d:DesignWidth="1200">
    <UserControl.Resources>

        <SolidColorBrush x:Key="Surface" Color="#0D0F12"/>
        <SolidColorBrush x:Key="SurfaceRaised" Color="#171A20"/>
        <SolidColorBrush x:Key="SurfaceActive" Color="#1E2530"/>
        <SolidColorBrush x:Key="BorderDim" Color="#2A2F38"/>
        <SolidColorBrush x:Key="BorderBright" Color="#3A4252"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F7"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8E9199"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#5A5E66"/>
        <SolidColorBrush x:Key="Accent" Color="#119EDA"/>
        <SolidColorBrush x:Key="StatusGreen" Color="#4ADE80"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionCount" TargetType="TextBlock" BasedOn="{StaticResource SectionLabel}">
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBright}"/>
                    <Setter Property="Background" Value="#141821"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ChannelTileTemplate" DataType="{x:Type vm:ChannelTileViewModel}">
            <Border Width="148" Height="88" Margin="0,0,10,10"
                    Background="{Binding TileBackground}"
                    BorderBrush="{Binding TileBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.ToggleChannelCommand, ElementName=Root}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="{Binding StripeBrush}"/>
                    <Grid Grid.Column="1" Margin="12,10,10,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Medium"/>
                            <TextBlock Text="{Binding Value}"
                                       Foreground="{Binding Channel.ChannelColorBrush}"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding TypeLabel}"
                                       Foreground="{StaticResource TextTertiary}"
                                       FontSize="9"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DeviceName}"
                                       Foreground="{StaticResource TextTertiary}"
                                       FontSize="9"
                                       Opacity="0.7"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding ShowDeviceLabel,
                                                            Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Width="18" Height="18"
                                Background="#33000000"
                                CornerRadius="9"
                                Margin="0,-2,-2,0"
                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"
                                ToolTip="Click tile to deactivate"
                                IsHitTestVisible="False">
                            <TextBlock Text="&#xD7;"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,-2,0,0"/>
                        </Border>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Width="22" Height="22"
                                Padding="0"
                                Margin="0,0,-2,-2"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Channel settings"
                                Command="{Binding DataContext.OpenSettingsCommand, ElementName=Root}"
                                CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg"
                                            Background="Transparent"
                                            CornerRadius="11">
                                        <iconPacks:PackIconMaterial Kind="Cog"
                                                                    Width="11" Height="11"
                                                                    Foreground="{StaticResource TextTertiary}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#33000000"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="TileWrap">
            <WrapPanel/>
        </ItemsPanelTemplate>

        <Style x:Key="DarkToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                CornerRadius="10"
                                Background="{StaticResource BorderDim}"
                                BorderBrush="{StaticResource BorderBright}"
                                BorderThickness="1">
                            <Grid>
                                <Ellipse x:Name="Thumb"
                                         Width="14" Height="14"
                                         Fill="{StaticResource TextSecondary}"
                                         HorizontalAlignment="Left"
                                         Margin="2,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="2"
                                Padding="10,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource SurfaceActive}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource Surface}">

        <!-- ========== CONNECTED STATE ========== -->
        <Grid Visibility="{Binding HasConnectedDevice, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="28,22,28,14">
                <TextBlock Text="CHANNELS"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextTertiary}"
                           Margin="0,0,0,2"/>

                <!-- Single-device header -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding HasMultipleDevices,
                                                 Converter={StaticResource InvertedBoolToVis}}">
                    <TextBlock Text="{Binding DeviceName}"
                               FontSize="24"
                               FontWeight="Light"
                               Foreground="{StaticResource TextPrimary}"/>
                    <Ellipse Width="6" Height="6"
                             Fill="{StaticResource StatusGreen}"
                             VerticalAlignment="Center"
                             Margin="12,2,8,0"/>
                    <TextBlock Text="CONNECTED"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource StatusGreen}"
                               VerticalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Multi-device chip row -->
                <StackPanel Visibility="{Binding HasMultipleDevices,
                                                 Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="24"
                               FontWeight="Light"
                               Foreground="{StaticResource TextPrimary}">
                        <Run Text="{Binding ConnectedDeviceNames.Count, Mode=OneWay}"/>
                        <Run Text=" DEVICES"/>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding ConnectedDeviceNames}" Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceRaised}"
                                        BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="10,5"
                                        Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{StaticResource StatusGreen}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- Sections -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="28,0,28,0">
                <StackPanel>

                    <!-- ANALOG IN -->
                    <Grid Margin="0,8,0,10"
                          Visibility="{Binding TotalAnalogCount, Converter={StaticResource IntToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ANALOG IN" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Style="{StaticResource SectionCount}">
                                <Run Text="· "/>
                                <Run Text="{Binding ActiveAnalogCount, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding TotalAnalogCount, Mode=OneWay}"/>
                                <Run Text=" ACTIVE"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Style="{StaticResource PillButton}"
                                HorizontalAlignment="Right"
                                Content="SELECT ALL"
                                Command="{Binding SelectAllCommand}"
                                CommandParameter="AI"/>
                    </Grid>
                    <Rectangle Height="1"
                               Fill="{StaticResource BorderDim}"
                               Margin="0,0,0,14"
                               Visibility="{Binding TotalAnalogCount, Converter={StaticResource IntToVisibility}}"/>
                    <ItemsControl ItemsSource="{Binding AnalogInputs}"
                                  ItemTemplate="{StaticResource ChannelTileTemplate}"
                                  ItemsPanel="{StaticResource TileWrap}"
                                  Margin="0,0,0,24"/>

                    <!-- DIGITAL IN -->
                    <Grid Margin="0,8,0,10"
                          Visibility="{Binding TotalDigitalInCount, Converter={StaticResource IntToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DIGITAL IN" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Style="{StaticResource SectionCount}">
                                <Run Text="· "/>
                                <Run Text="{Binding ActiveDigitalInCount, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding TotalDigitalInCount, Mode=OneWay}"/>
                                <Run Text=" ACTIVE"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Style="{StaticResource PillButton}"
                                HorizontalAlignment="Right"
                                Content="SELECT ALL"
                                Command="{Binding SelectAllCommand}"
                                CommandParameter="DI"/>
                    </Grid>
                    <Rectangle Height="1"
                               Fill="{StaticResource BorderDim}"
                               Margin="0,0,0,14"
                               Visibility="{Binding TotalDigitalInCount, Converter={StaticResource IntToVisibility}}"/>
                    <ItemsControl ItemsSource="{Binding DigitalInputs}"
                                  ItemTemplate="{StaticResource ChannelTileTemplate}"
                                  ItemsPanel="{StaticResource TileWrap}"
                                  Margin="0,0,0,24"/>

                    <!-- DIGITAL OUT -->
                    <Grid Margin="0,8,0,10"
                          Visibility="{Binding TotalDigitalOutCount, Converter={StaticResource IntToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DIGITAL OUT" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Style="{StaticResource SectionCount}">
                                <Run Text="· "/>
                                <Run Text="{Binding ActiveDigitalOutCount, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding TotalDigitalOutCount, Mode=OneWay}"/>
                                <Run Text=" ACTIVE"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Style="{StaticResource PillButton}"
                                HorizontalAlignment="Right"
                                Content="SELECT ALL"
                                Command="{Binding SelectAllCommand}"
                                CommandParameter="DO"/>
                    </Grid>
                    <Rectangle Height="1"
                               Fill="{StaticResource BorderDim}"
                               Margin="0,0,0,14"
                               Visibility="{Binding TotalDigitalOutCount, Converter={StaticResource IntToVisibility}}"/>
                    <ItemsControl ItemsSource="{Binding DigitalOutputs}"
                                  ItemTemplate="{StaticResource ChannelTileTemplate}"
                                  ItemsPanel="{StaticResource TileWrap}"
                                  Margin="0,0,0,32"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="2"
                    Background="#0A0C10"
                    BorderBrush="{StaticResource BorderDim}"
                    BorderThickness="0,1,0,0"
                    Padding="28,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource StatusGreen}"
                                 Margin="0,0,10,0"/>
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding TotalActive, Mode=OneWay}"/>
                            <Run Text=" CHANNELS ACTIVE"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource PillButton}"
                                Content="CLEAR ALL"
                                Command="{Binding ClearAllCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== SETTINGS DRAWER ========== -->
        <Grid Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Scrim -->
            <Rectangle Grid.Column="0" Fill="#A0000000">
                <Rectangle.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseSettingsCommand}"/>
                </Rectangle.InputBindings>
            </Rectangle>

            <!-- Drawer -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceRaised}"
                    BorderBrush="{StaticResource BorderDim}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="22,22,16,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0"
                                   Width="3" Height="32"
                                   Fill="{Binding SelectedChannel.ChannelColorBrush}"
                                   Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="CHANNEL"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiary}"/>
                            <TextBlock Text="{Binding SelectedChannel.Name}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource TextSecondary}"
                                FontSize="16"
                                Cursor="Hand"
                                Content="&#xD7;"
                                Command="{Binding CloseSettingsCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="14">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#1FFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,0,22,22">
                        <StackPanel>

                            <!-- NAME -->
                            <TextBlock Text="NAME"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="0,8,0,8"/>
                            <Border Background="{StaticResource Surface}"
                                    BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="10,0">
                                <TextBox Text="{Binding SelectedChannel.Name, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource TextPrimary}"
                                         FontFamily="Consolas"
                                         FontSize="14"
                                         Height="32"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="{StaticResource TextPrimary}"/>
                            </Border>

                            <!-- COLOR -->
                            <TextBlock Text="COLOR"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="0,22,0,8"/>
                            <ItemsControl ItemsSource="{Binding Palette}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="36" Height="36" Margin="0,0,8,8">
                                            <!-- Selection ring -->
                                            <Border CornerRadius="5"
                                                    BorderBrush="{StaticResource TextPrimary}"
                                                    BorderThickness="2">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource BrushColorMatch}">
                                                        <Binding/>
                                                        <Binding ElementName="Root"
                                                                 Path="DataContext.SelectedChannel.ChannelColorBrush"/>
                                                    </MultiBinding>
                                                </Border.Visibility>
                                            </Border>
                                            <!-- Swatch -->
                                            <Button Width="28" Height="28"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.SetColorCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg"
                                                                Background="{Binding}"
                                                                BorderBrush="Transparent"
                                                                BorderThickness="1"
                                                                CornerRadius="3"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg"
                                                                        Property="BorderBrush"
                                                                        Value="{StaticResource TextSecondary}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- DIRECTION (bidirectional only) -->
                            <StackPanel Visibility="{Binding SelectedChannel.IsBidirectional,
                                                             Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="DIRECTION"
                                           Style="{StaticResource SectionLabel}"
                                           Margin="0,22,0,8"/>
                                <Border Background="{StaticResource Surface}"
                                        BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Grid.Column="0"
                                                     Content="INPUT"
                                                     IsChecked="{Binding SelectedChannel.IsOutput,
                                                                         Converter={StaticResource BooleanToInverse}}"
                                                     Style="{StaticResource SegmentedToggle}"/>
                                        <RadioButton Grid.Column="1"
                                                     Content="OUTPUT"
                                                     IsChecked="{Binding SelectedChannel.IsOutput}"
                                                     Style="{StaticResource SegmentedToggle}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- DIGITAL OUTPUT STATE -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding SelectedChannel.IsDigital}"
                                                               Value="True"/>
                                                    <Condition Binding="{Binding SelectedChannel.IsOutput}"
                                                               Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="OUTPUT STATE"
                                           Style="{StaticResource SectionLabel}"
                                           Margin="0,22,0,8"/>
                                <Border Background="{StaticResource Surface}"
                                        BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Grid.Column="0"
                                                     Content="LOW"
                                                     IsChecked="{Binding SelectedChannel.IsDigitalOn,
                                                                         Converter={StaticResource BooleanToInverse}}"
                                                     Style="{StaticResource SegmentedToggle}"/>
                                        <RadioButton Grid.Column="1"
                                                     Content="HIGH"
                                                     IsChecked="{Binding SelectedChannel.IsDigitalOn}"
                                                     Style="{StaticResource SegmentedToggle}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- SCALING (analog only) -->
                            <StackPanel Visibility="{Binding SelectedChannel.IsAnalog,
                                                             Converter={StaticResource BoolToVis}}">
                                <Grid Margin="0,22,0,8">
                                    <TextBlock Text="SCALING"
                                               Style="{StaticResource SectionLabel}"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding SelectedChannel.IsScalingActive}"
                                                  Style="{StaticResource DarkToggleSwitch}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                                <Border Background="{StaticResource Surface}"
                                        BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="10,0"
                                        IsEnabled="{Binding SelectedChannel.IsScalingActive}">
                                    <TextBox Text="{Binding SelectedChannel.ScaleExpression,
                                                                    UpdateSourceTrigger=PropertyChanged,
                                                                    Delay=300}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource TextPrimary}"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             Height="32"
                                             VerticalContentAlignment="Center"
                                             CaretBrush="{StaticResource TextPrimary}"/>
                                </Border>
                                <TextBlock Text="e.g. x * 2 + 1   (x = raw value)"
                                           FontSize="10"
                                           Foreground="{StaticResource TextTertiary}"
                                           Margin="0,6,0,0"/>
                                <TextBlock Text="INVALID EXPRESSION"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#F43F5E"
                                           Margin="0,6,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding SelectedChannel.IsScalingActive}"
                                                                   Value="True"/>
                                                        <Condition
                                                            Binding="{Binding SelectedChannel.HasValidExpression}"
                                                            Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== EMPTY STATE ========== -->
        <Grid Visibility="{Binding HasConnectedDevice, Converter={StaticResource InvertedBoolToVis}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="420">
                <Border Width="96" Height="96"
                        CornerRadius="48"
                        Background="{StaticResource SurfaceRaised}"
                        BorderBrush="{StaticResource BorderDim}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,28">
                    <iconPacks:PackIconMaterial Kind="Chip"
                                                Width="40" Height="40"
                                                Foreground="{StaticResource TextTertiary}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="NO DEVICE CONNECTED"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextTertiary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Connect a DAQiFi device to view and activate channels."
                           FontSize="15"
                           FontWeight="Light"
                           Foreground="{StaticResource TextPrimary}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                <TextBlock Text="Open the Devices tab to get started"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
