<UserControl x:Class="Daqifi.Desktop.View.Prototype.DevicesPanePrototype"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:vm="clr-namespace:Daqifi.Desktop.ViewModels"
             xmlns:networkDataModel="clr-namespace:Daqifi.Core.Device.Network;assembly=Daqifi.Core"
             xmlns:sdCard="clr-namespace:Daqifi.Core.Device.SdCard;assembly=Daqifi.Core"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DevicesPaneViewModel}"
             d:DesignHeight="800" d:DesignWidth="1200">
    <UserControl.Resources>

        <!-- Brushes (Surface, BorderDim, TextPrimary, Accent, StatusAmber, …) come from /Resources/DesignTokens.xaml via App.xaml. -->


        <ObjectDataProvider MethodName="GetValues" ObjectType="{x:Type sys:Enum}" x:Key="SdCardLogFormats">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="sdCard:SdCardLogFormat"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider MethodName="GetValues" ObjectType="{x:Type sys:Enum}" x:Key="WifiModes">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="networkDataModel:WifiMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider MethodName="GetValues" ObjectType="{x:Type sys:Enum}" x:Key="WifiSecurityTypes">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="networkDataModel:WifiSecurityType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DrawerSectionLabel" TargetType="TextBlock" BasedOn="{StaticResource SectionLabel}">
            <Setter Property="Margin" Value="0,22,0,8"/>
        </Style>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBright}"/>
                    <Setter Property="Background" Value="#141821"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentPillButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1EB3F0"/>
                    <Setter Property="BorderBrush" Value="#1EB3F0"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerPillButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="BorderBrush" Value="#4A1F28"/>
            <Setter Property="Foreground" Value="{StaticResource StatusRed}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A0F14"/>
                    <Setter Property="BorderBrush" Value="{StaticResource StatusRed}"/>
                    <Setter Property="Foreground" Value="{StaticResource StatusRed}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DrawerTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="DrawerTextField" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <!-- ComboBox item container: dark row with active-surface hover -->
        <Style x:Key="DrawerComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource SurfaceActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            Full dark ComboBox template. The app's MahApps Light.Blue theme
            paints the default ComboBox toggle button white regardless of the
            Background setter, so we replace the ControlTemplate outright and
            drive color from our palette.
        -->
        <Style x:Key="DrawerComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DrawerComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Bg"
                                    Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>

                            <ContentPresenter Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>

                            <ToggleButton Grid.Column="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding Path=IsDropDownOpen,
                                                      Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="{StaticResource TextSecondary}"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   Placement="Bottom">
                                <Border Background="{StaticResource SurfaceRaised}"
                                        BorderBrush="{StaticResource BorderDim}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource BorderBright}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="2"
                                Padding="10,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource SurfaceActive}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="DeviceTileTemplate" DataType="{x:Type vm:DeviceTileViewModel}">
            <Border Width="280" Height="116" Margin="0,0,12,12"
                    Background="{Binding TileBackground}"
                    BorderBrush="{Binding TileBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.OpenSettingsCommand, ElementName=Root}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="{Binding StripeBrush}"/>
                    <Grid Grid.Column="1" Margin="14,12,12,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Name + connection chip -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontFamily="Consolas"
                                       FontSize="18"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <Border Grid.Column="1"
                                    Background="#141821"
                                    BorderBrush="{Binding StripeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="6,2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding ConnectionLabel}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding StripeBrush}"/>
                            </Border>
                        </Grid>

                        <!-- Identity -->
                        <StackPanel Grid.Row="1" Margin="0,6,0,0">
                            <TextBlock Text="{Binding Identifier}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="{Binding SerialNumber}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Margin="0,2,0,0"
                                       Foreground="{StaticResource TextTertiary}"/>
                        </StackPanel>

                        <!-- Bottom row: firmware + gear -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="FW"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextTertiary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Version}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Margin="6,0,0,0"
                                           Foreground="{StaticResource TextSecondary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#2A1A0A"
                                    BorderBrush="{StaticResource StatusAmber}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="6,2"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsFirmwareOutdated,
                                                         Converter={StaticResource BoolToVis}}"
                                    ToolTip="A firmware update is available for this device.">
                                <TextBlock Text="UPDATE"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource StatusAmber}"/>
                            </Border>

                            <Button Grid.Column="2"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Device settings"
                                    Command="{Binding DataContext.OpenSettingsCommand, ElementName=Root}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg"
                                                Background="Transparent"
                                                CornerRadius="11">
                                            <iconPacks:PackIconMaterial Kind="Cog"
                                                                        Width="11" Height="11"
                                                                        Foreground="{StaticResource TextTertiary}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#33000000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="TileWrap">
            <WrapPanel/>
        </ItemsPanelTemplate>

    </UserControl.Resources>

    <Grid Background="{StaticResource Surface}">

        <!-- ========== CONNECTED STATE ========== -->
        <Grid Visibility="{Binding HasConnectedDevice, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="28,22,28,14">
                <TextBlock Text="DEVICES"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextTertiary}"
                           Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="24"
                               FontWeight="Light"
                               Foreground="{StaticResource TextPrimary}">
                        <Run Text="{Binding Devices.Count, Mode=OneWay}"/>
                        <Run Text=" CONNECTED"/>
                    </TextBlock>
                    <Ellipse Width="6" Height="6"
                             Fill="{StaticResource StatusGreen}"
                             VerticalAlignment="Center"
                             Margin="14,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Tiles -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="28,0,28,0">
                <ItemsControl ItemsSource="{Binding Devices}"
                              ItemTemplate="{StaticResource DeviceTileTemplate}"
                              ItemsPanel="{StaticResource TileWrap}"
                              Margin="0,0,0,24"/>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="2"
                    Background="#0A0C10"
                    BorderBrush="{StaticResource BorderDim}"
                    BorderThickness="0,1,0,0"
                    Padding="28,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource StatusGreen}"
                                 Margin="0,0,10,0"/>
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding Devices.Count, Mode=OneWay}"/>
                            <Run Text=" DEVICES CONNECTED"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource AccentPillButton}"
                                Content="+ ADD DEVICE"
                                Command="{Binding AddDeviceCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== SETTINGS DRAWER ========== -->
        <Grid Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- Scrim -->
            <Rectangle Grid.Column="0" Fill="#A0000000">
                <Rectangle.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseSettingsCommand}"/>
                </Rectangle.InputBindings>
            </Rectangle>

            <!-- Drawer -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceRaised}"
                    BorderBrush="{StaticResource BorderDim}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="22,22,16,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0"
                                   Width="3" Height="32"
                                   Fill="{Binding SelectedTile.StripeBrush}"
                                   Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="DEVICE"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiary}"/>
                            <TextBlock Text="{Binding SelectedTile.Name}"
                                       FontFamily="Consolas"
                                       FontSize="20"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource TextSecondary}"
                                FontSize="16"
                                Cursor="Hand"
                                Content="&#xD7;"
                                Command="{Binding CloseSettingsCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="14">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#1FFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,0,22,22">
                        <StackPanel>

                            <!-- INFORMATION -->
                            <TextBlock Text="INFORMATION" Style="{StaticResource SectionLabel}" Margin="0,8,0,10"/>
                            <Border Background="{StaticResource Surface}"
                                    BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="CONNECTION" Style="{StaticResource InfoLabel}"/>
                                        <TextBlock Text="{Binding SelectedTile.ConnectionLabel}"
                                                   Style="{StaticResource InfoValue}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="IDENTIFIER" Style="{StaticResource InfoLabel}"/>
                                        <TextBlock Text="{Binding SelectedTile.Identifier}"
                                                   Style="{StaticResource InfoValue}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="0" Grid.Row="1">
                                        <TextBlock Text="SERIAL" Style="{StaticResource InfoLabel}"/>
                                        <TextBlock Text="{Binding SelectedTile.SerialNumber}"
                                                   Style="{StaticResource InfoValue}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="1">
                                        <TextBlock Text="FIRMWARE" Style="{StaticResource InfoLabel}"/>
                                        <TextBlock Text="{Binding SelectedTile.Version}"
                                                   Style="{StaticResource InfoValue}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- DATA ACQUISITION -->
                            <TextBlock Text="DATA ACQUISITION" Style="{StaticResource DrawerSectionLabel}"/>

                            <TextBlock Text="LOGGING MODE" Style="{StaticResource InfoLabel}" Margin="0,0,0,6"/>
                            <Border Background="{StaticResource Surface}"
                                    BorderBrush="{StaticResource BorderDim}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton Grid.Column="0"
                                                 Content="STREAM TO APP"
                                                 GroupName="LoggingMode"
                                                 IsChecked="{Binding Shell.IsLogToDeviceMode,
                                                             Converter={StaticResource BooleanToInverse}, Mode=OneWay}"
                                                 Style="{StaticResource SegmentedToggle}"
                                                 Command="{Binding SetLoggingModeCommand}"
                                                 CommandParameter="Stream to App"/>
                                    <RadioButton Grid.Column="1"
                                                 Content="LOG TO DEVICE"
                                                 GroupName="LoggingMode"
                                                 IsEnabled="{Binding SelectedTile.IsUsb}"
                                                 IsChecked="{Binding Shell.IsLogToDeviceMode, Mode=OneWay}"
                                                 Style="{StaticResource SegmentedToggle}"
                                                 Command="{Binding SetLoggingModeCommand}"
                                                 CommandParameter="Log to Device"
                                                 ToolTip="SD card logging requires USB. WiFi devices do not support SD card logging."/>
                                </Grid>
                            </Border>

                            <TextBlock Text="FREQUENCY (Hz)" Style="{StaticResource InfoLabel}" Margin="0,16,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Style="{StaticResource DrawerTextField}"
                                        Width="80"
                                        Margin="0,0,10,0">
                                    <TextBox Text="{Binding ElementName=FrequencySlider, Path=Value,
                                                     UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                             Style="{StaticResource DrawerTextBox}"
                                             TextAlignment="Center"
                                             FontSize="16"/>
                                </Border>
                                <Slider Grid.Column="1"
                                        x:Name="FrequencySlider"
                                        Minimum="1" Maximum="1000"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"
                                        Value="{Binding FrequencyHz,
                                                Delay=500, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <!-- DATA FORMAT (visible only when logging to device) -->
                            <StackPanel Visibility="{Binding Shell.IsLogToDeviceMode,
                                                     Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="DATA FORMAT" Style="{StaticResource InfoLabel}" Margin="0,16,0,6"/>
                                <ComboBox Style="{StaticResource DrawerComboBox}"
                                          ItemsSource="{Binding Source={StaticResource SdCardLogFormats}}"
                                          SelectedItem="{Binding Shell.SelectedSdCardLogFormat, Mode=TwoWay}"/>
                            </StackPanel>

                            <!-- NETWORK -->
                            <TextBlock Text="NETWORK" Style="{StaticResource DrawerSectionLabel}"/>

                            <TextBlock Text="MODE" Style="{StaticResource InfoLabel}" Margin="0,0,0,6"/>
                            <ComboBox Style="{StaticResource DrawerComboBox}"
                                      ItemsSource="{Binding Source={StaticResource WifiModes}}"
                                      SelectedItem="{Binding SelectedDevice.NetworkConfiguration.Mode}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="SECURITY" Style="{StaticResource InfoLabel}" Margin="0,14,0,6"/>
                            <ComboBox Style="{StaticResource DrawerComboBox}"
                                      ItemsSource="{Binding Source={StaticResource WifiSecurityTypes}}"
                                      SelectedItem="{Binding SelectedDevice.NetworkConfiguration.SecurityType}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescription}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="SSID" Style="{StaticResource InfoLabel}" Margin="0,14,0,6"/>
                            <Border Style="{StaticResource DrawerTextField}">
                                <TextBox Style="{StaticResource DrawerTextBox}"
                                         Text="{Binding SelectedDevice.NetworkConfiguration.Ssid, Mode=TwoWay}"/>
                            </Border>

                            <TextBlock Text="PASSWORD" Style="{StaticResource InfoLabel}" Margin="0,14,0,6"/>
                            <Border Style="{StaticResource DrawerTextField}">
                                <TextBox Style="{StaticResource DrawerTextBox}"
                                         Text="{Binding SelectedDevice.NetworkConfiguration.Password, Mode=TwoWay}"/>
                            </Border>

                            <Button Style="{StaticResource AccentPillButton}"
                                    Content="APPLY NETWORK SETTINGS"
                                    HorizontalAlignment="Right"
                                    Margin="0,14,0,0"
                                    Command="{Binding Shell.UpdateNetworkConfigurationCommand}"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding Shell.NetworkSettingsApplied, Converter={StaticResource BoolToVis}}">
                                <iconPacks:PackIconMaterial Kind="CheckCircleOutline"
                                                            Width="12" Height="12"
                                                            Foreground="{StaticResource StatusGreen}"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,6,0"/>
                                <TextBlock Text="Settings applied"
                                           Foreground="{StaticResource StatusGreen}"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding Shell.HasNetworkSettingsError, Converter={StaticResource BoolToVis}}">
                                <iconPacks:PackIconMaterial Kind="AlertCircleOutline"
                                                            Width="12" Height="12"
                                                            Foreground="{StaticResource StatusRed}"
                                                            VerticalAlignment="Top"
                                                            Margin="0,2,6,0"/>
                                <TextBlock Text="{Binding Shell.NetworkSettingsError}"
                                           Foreground="{StaticResource StatusRed}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           MaxWidth="320"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- FIRMWARE -->
                            <TextBlock Text="FIRMWARE" Style="{StaticResource DrawerSectionLabel}"/>

                            <!-- USB: file picker + upload -->
                            <StackPanel Visibility="{Binding SelectedDeviceSupportsFirmwareUpdate,
                                                     Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="FIRMWARE FILE" Style="{StaticResource InfoLabel}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource DrawerTextField}" Margin="0,0,8,0">
                                        <TextBox Style="{StaticResource DrawerTextBox}"
                                                 Text="{Binding Shell.FirmwareFilePath, Mode=TwoWay}"/>
                                    </Border>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource PillButton}"
                                            Content="BROWSE"
                                            Command="{Binding Shell.BrowseForFirmwareCommand}"/>
                                </Grid>

                                <TextBlock Text="PROGRESS" Style="{StaticResource InfoLabel}" Margin="0,16,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0"
                                                 Height="10"
                                                 VerticalAlignment="Center"
                                                 Minimum="0" Maximum="100"
                                                 Background="{StaticResource Surface}"
                                                 Foreground="{StaticResource Accent}"
                                                 BorderBrush="{StaticResource BorderDim}"
                                                 Value="{Binding Shell.UploadFirmwareProgress}"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource AccentPillButton}"
                                            Content="UPDATE"
                                            Margin="8,0,0,0"
                                            Command="{Binding Shell.UploadFirmwareCommand}"/>
                                </Grid>
                            </StackPanel>

                            <!-- WiFi: informational message -->
                            <Border Background="#2A1A0A"
                                    BorderBrush="{StaticResource StatusAmber}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="12,10"
                                    Visibility="{Binding SelectedDeviceSupportsFirmwareUpdate,
                                                 Converter={StaticResource InvertedBoolToVis}}">
                                <TextBlock Text="Firmware updates require a USB connection."
                                           FontSize="11"
                                           Foreground="{StaticResource StatusAmber}"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <!-- ACTIONS -->
                            <TextBlock Text="ACTIONS" Style="{StaticResource DrawerSectionLabel}"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PillButton}"
                                        Content="REBOOT"
                                        Command="{Binding RebootSelectedCommand}"/>
                                <Button Style="{StaticResource DangerPillButton}"
                                        Content="DISCONNECT"
                                        Command="{Binding DisconnectSelectedCommand}"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== EMPTY STATE ========== -->
        <Grid Visibility="{Binding HasConnectedDevice, Converter={StaticResource InvertedBoolToVis}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="420">
                <Border Width="96" Height="96"
                        CornerRadius="48"
                        Background="{StaticResource SurfaceRaised}"
                        BorderBrush="{StaticResource BorderDim}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,28">
                    <iconPacks:PackIconMaterial Kind="Chip"
                                                Width="40" Height="40"
                                                Foreground="{StaticResource TextTertiary}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="NO DEVICES CONNECTED"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextTertiary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Connect a DAQiFi device over USB or WiFi to get started."
                           FontSize="15"
                           FontWeight="Light"
                           Foreground="{StaticResource TextPrimary}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                <Button Style="{StaticResource AccentPillButton}"
                        Content="+ ADD DEVICE"
                        HorizontalAlignment="Center"
                        Command="{Binding AddDeviceCommand}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
